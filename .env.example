# --- Telegram bots (from @BotFather) ---
LEADS_BOT_TOKEN=123456:ABC-leads-token
SUPPORT_BOT_TOKEN=123456:ABC-support-token

# --- Chat IDs (negative for groups/supergroups) ---
LEADS_CHAT_ID=-1001234567890
SUPPORT_CHAT_ID=-1001234567890
# Forum (topics) supergroup gives each support ticket its own thread for the relay.
SUPPORT_FORUM=true

# --- OUR ops Postgres (NOT Lovable's). A Supabase project you own, or Render PG. ---
# Stores lead/ticket state + claim status. Lovable Cloud's DB is unreachable, so we
# keep our own. Use the "session" pooler / direct connection string.
DATABASE_URL=postgresql://postgres:[password]@db.<ref>.supabase.co:5432/postgres

# --- Public URL of this service (Render) — used to register Telegram webhooks ---
PUBLIC_BASE_URL=https://turkarta-operations.onrender.com

# --- Shared secrets ---
# Sent by the Lovable form / edge function as header  X-Webhook-Secret
LEADS_WEBHOOK_SECRET=change-me-lead-ingest
# Path + header secret for Telegram webhooks
TELEGRAM_WEBHOOK_SECRET=change-me-telegram

# --- Roster: who gets @-mentioned + who can claim ---
# JSON array. tg_id optional but lets the bot mention people without a @username.
ROSTER=[{"name":"Artem","username":"artem_tk","tg_id":111111111}]

PORT=8000
