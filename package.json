{
  "name": "turkarta-operations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turkarta operations hub: leads + support Telegram bots",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node --import tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "grammy": "^1.32.0",
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@11.5.0"
}
